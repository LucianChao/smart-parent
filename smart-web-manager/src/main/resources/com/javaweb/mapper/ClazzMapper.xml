<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.javaweb.mapper.ClazzMapper">
    <!--新增班级-->
    <insert id="save">
        insert into clazz
        VALUES (null, #{name}, #{room}, #{beginDate}, #{endDate}, #{masterId}, #{subject}, #{createTime}, #{updateTime})
    </insert>
    <!--修改班级-->
    <update id="update">
        update clazz set
        name = #{name},
        room = #{room},
        begin_date = #{beginDate},
        end_date = #{endDate},
        master_id = #{masterId},
        subject = #{subject},
        update_time = #{updateTime}
        where id = #{id}
    </update>
    <!--删除班级-->
    <delete id="delete">
        delete
        from clazz
        where id = #{id}
    </delete>
    <!--条件查询-->
    <select id="page" resultType="com.javaweb.entity.Clazz">
        select
        c.*,
        e.name masterName
        from clazz c
        left join emp e on c.master_id = e.id
        <where>
            <if test="name != null and name != ''">
                c.name like concat('%',#{name},'%')
            </if>
            <if test="begin != null and end != null">
                and c.end_date between #{begin} and #{end}
            </if>
        </where>
        order by c.update_time desc
    </select>
    <!--根据ID查询-->
    <select id="getById" resultType="com.javaweb.entity.Clazz">
        select * from clazz where id = #{id}
    </select>
    <!--查询所有班级-->
    <select id="list" resultType="com.javaweb.entity.Clazz">
        select * from clazz
    </select>
</mapper>